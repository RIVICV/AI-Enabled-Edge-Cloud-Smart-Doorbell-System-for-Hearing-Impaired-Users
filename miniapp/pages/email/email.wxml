<view class="container">
  <view class="card">
    <view class="card-header">
      <text class="card-title">✉️ 紧急联系人邮箱</text>
      <text class="card-subtitle">紧急呼叫时，系统将发送邮件到此邮箱</text>
    </view>

    <view class="form-group">
      <text class="form-label">邮箱地址</text>
      <input 
        class="form-input" 
        placeholder="请输入子女的邮箱地址"
        value="{{email}}"
        bindinput="onEmailInput"
        type="text"
        confirm-type="done"
        bindconfirm="saveEmail"
      />
      <text class="form-hint" wx:if="{{emailHint}}">{{emailHint}}</text>
    </view>

    <view class="button-group">
      <button class="save-btn" bindtap="saveEmail" disabled="{{!email}}">
        保存设置
      </button>
      <button class="test-btn" bindtap="testEmail" disabled="{{!email}}">
        发送测试邮件
      </button>
    </view>

    <view class="info-tip">
      <text class="info-icon">💡</text>
      <text class="info-text">设置后，每次紧急呼叫都会发送邮件到该地址</text>
    </view>
  </view>
</view>