<!-- 优雅版首页 -->
<view class="container">
  <!-- ===== 顶部状态栏 ===== -->
  <view class="header">
    <view class="header-glow"></view>
    <view class="header-top">
      <view class="header-left">
        <view class="header-logo">
          <text class="header-icon">🌱</text>
        </view>
        <view class="header-info">
          <text class="header-title">智能门铃</text>
          <text class="header-sub">听障人士 · 多模态感知</text>
        </view>
      </view>
      <view class="header-right">
        <view class="header-time">{{currentTime}}</view>
        <view class="status-badge {{isOnline ? 'online' : 'offline'}}">
          <view class="status-dot"></view>
          <text>{{isOnline ? '已连接' : '未连接'}}</text>
        </view>
      </view>
    </view>
    <!-- 问候语 + 今日统计 -->
    <view class="greeting-section">
      <view class="greeting-left">
        <text class="greeting-emoji">☀️</text>
        <text class="greeting-text">{{greetingText}}，今天有 <text class="greeting-highlight">{{todayCount}}</text> 次来访</text>
      </view>
      <view class="today-stats">
        <text class="today-number">{{todayCount}}</text>
        <text class="today-label">今日</text>
      </view>
    </view>
    <!-- 装饰元素 -->
    <view class="header-decoration">
      <view class="leaf leaf-1"></view>
      <view class="leaf leaf-2"></view>
      <view class="leaf leaf-3"></view>
      <view class="leaf leaf-4"></view>
      <view class="leaf leaf-5"></view>
    </view>
  </view>

  <!-- ===== 设备状态卡片 ===== -->
  <view class="card status-card">
    <view class="status-grid">
      <view class="status-item">
        <view class="status-icon-wrap wifi">
          <text class="status-item-icon">📶</text>
        </view>
        <text class="status-item-label">WiFi</text>
        <text class="status-item-value online-text">已连接</text>
      </view>
      <view class="status-divider"></view>
      <view class="status-item">
        <view class="status-icon-wrap mqtt">
          <text class="status-item-icon">🔗</text>
        </view>
        <text class="status-item-label">MQTT</text>
        <text class="status-item-value online-text">已连接</text>
      </view>
      <view class="status-divider"></view>
      <view class="status-item">
        <view class="status-icon-wrap server">
          <text class="status-item-icon">☁️</text>
        </view>
        <text class="status-item-label">服务器</text>
        <text class="status-item-value online-text">运行中</text>
      </view>
      <view class="status-divider"></view>
      <view class="status-item">
        <view class="status-icon-wrap stats">
          <text class="status-item-icon">📊</text>
        </view>
        <text class="status-item-label">今日来访</text>
        <text class="status-item-value highlight">{{todayCount}} 次</text>
      </view>
    </view>
  </view>

  <!-- ===== AI 问答卡片 ===== -->
  <view class="card chat-card">
    <view class="card-header">
      <view class="card-header-left">
        <view class="card-icon-wrap">
          <text class="card-icon">💬</text>
        </view>
        <view>
          <text class="card-title">AI 智能问答</text>
          <text class="card-subtitle">随时了解来访情况</text>
        </view>
      </view>
      <view class="card-badge">✨ AI</view>
    </view>
    
    <view class="input-wrapper">
      <view class="input-icon">🔍</view>
      <input 
        class="question-input"
        placeholder="输入你想问的问题..."
        bindinput="onInput"
        value="{{question}}"
        confirm-type="send"
        bindconfirm="askQuestion"
      />
      <button class="send-btn {{question ? 'active' : ''}}" bindtap="askQuestion">
        <text class="send-icon">➤</text>
      </button>
    </view>

    <!-- AI 回答 -->
    <view class="answer-area" wx:if="{{answer}}">
      <view class="answer-header">
        <view class="answer-avatar">🤖</view>
        <view class="answer-info">
          <text class="answer-name">AI 助手</text>
          <text class="answer-time">{{currentTime}}</text>
        </view>
        <view class="answer-badge">已生成</view>
      </view>
      <view class="answer-content">{{answer}}</view>
    </view>

    <!-- 快捷提问 -->
    <view class="quick-section">
      <text class="quick-label">⚡ 快捷提问</text>
      <view class="quick-grid">
        <view class="quick-item" bindtap="quickAsk" data-q="最近有人来过吗？">
          <view class="quick-icon-wrap">
            <text class="quick-icon">🔔</text>
          </view>
          <text>最近有人来过吗？</text>
        </view>
        <view class="quick-item" bindtap="quickAsk" data-q="今天有来访吗？">
          <view class="quick-icon-wrap">
            <text class="quick-icon">📅</text>
          </view>
          <text>今天有来访吗？</text>
        </view>
        <view class="quick-item" bindtap="quickAsk" data-q="上周有几次来访？">
          <view class="quick-icon-wrap">
            <text class="quick-icon">📊</text>
          </view>
          <text>上周有几次来访？</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 最近来访卡片 ===== -->
  <view class="card recent-card">
    <view class="card-header">
      <view class="card-header-left">
        <view class="card-icon-wrap green">
          <text class="card-icon">📋</text>
        </view>
        <view>
          <text class="card-title">最近来访</text>
          <text class="card-subtitle">最新 {{recentRecords.length}} 条记录</text>
        </view>
      </view>
      <text class="card-more" bindtap="goHistory">查看全部 ›</text>
    </view>
    
    <view wx:if="{{recentRecords.length > 0}}" class="recent-list">
      <view wx:for="{{recentRecords}}" wx:key="id" class="recent-item {{index === 0 ? 'new-item' : ''}}">
        <view class="recent-left">
          <view class="recent-dot {{item.event_type === 'emergency' ? 'emergency-dot' : ''}}"></view>
          <view class="recent-info">
            <text class="recent-time">{{item.trigger_time}}</text>
            <text class="recent-type">{{item.event_type === 'emergency' ? '🚨 紧急' : '🔔 门铃'}}</text>
          </view>
        </view>
        <view class="recent-right">
          <view class="recent-tag">
            <text class="recent-msg">{{item.msg_content || '普通来访'}}</text>
          </view>
          <view class="new-badge" wx:if="{{index === 0}}">最新</view>
        </view>
      </view>
    </view>
    
    <view wx:else class="empty-state">
      <view class="empty-icon-wrap">
        <text class="empty-icon">🌱</text>
      </view>
      <text class="empty-text">暂无来访记录</text>
      <text class="empty-hint">门铃响起后这里会显示</text>
    </view>
  </view>

  <!-- ===== 底部信息 ===== -->
  <view class="footer">
    <view class="footer-line"></view>
    <view class="footer-content">
      <view class="footer-status">
        <view class="footer-dot"></view>
        <text class="footer-status-text">系统运行中 · 7×24 小时</text>
      </view>
      <text class="footer-text">🌱 听障人士智能门铃系统</text>
      <text class="footer-version">v1.0 · ESP32-S3</text>
    </view>
  </view>
</view>