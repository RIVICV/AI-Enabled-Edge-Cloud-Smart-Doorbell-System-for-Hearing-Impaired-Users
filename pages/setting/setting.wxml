<view class="container">
  <view class="profile-section">
    <view class="profile-avatar">
      <text class="profile-avatar-icon">🏠</text>
    </view>
    <text class="profile-name">智能门铃系统</text>
    <text class="profile-desc">听障人士智能门铃 · 蓝色守护</text>
  </view>

  <view class="card">
    <view class="setting-item">
      <view class="setting-left">
        <view class="setting-icon-wrap blue">
          <text class="setting-icon">📶</text>
        </view>
        <text class="setting-label">设备状态</text>
      </view>
      <view class="setting-right">
        <view class="status-dot-blue"></view>
        <text class="status-online">在线</text>
      </view>
    </view>
    <view class="setting-divider"></view>
    <view class="setting-item">
      <view class="setting-left">
        <view class="setting-icon-wrap blue">
          <text class="setting-icon">📡</text>
        </view>
        <text class="setting-label">服务器地址</text>
      </view>
      <text class="setting-value">{{serverUrl}}</text>
    </view>
    <view class="setting-divider"></view>
    <view class="setting-item">
      <view class="setting-left">
        <view class="setting-icon-wrap blue">
          <text class="setting-icon">📋</text>
        </view>
        <text class="setting-label">总来访次数</text>
      </view>
      <text class="setting-value">{{totalCount}} 次</text>
    </view>
    <view class="setting-divider"></view>
    <view class="setting-item">
      <view class="setting-left">
        <view class="setting-icon-wrap blue">
          <text class="setting-icon">🔔</text>
        </view>
        <text class="setting-label">今日来访</text>
      </view>
      <text class="setting-value">{{todayCount}} 次</text>
    </view>
  </view>

  <view class="card">
    <view class="setting-item">
      <view class="setting-left">
        <view class="setting-icon-wrap blue">
          <text class="setting-icon">📱</text>
        </view>
        <text class="setting-label">小程序版本</text>
      </view>
      <text class="setting-value">v1.0.0</text>
    </view>
    <view class="setting-divider"></view>
    <view class="setting-item">
      <view class="setting-left">
        <view class="setting-icon-wrap blue">
          <text class="setting-icon">💻</text>
        </view>
        <text class="setting-label">系统名称</text>
      </view>
      <text class="setting-value">智能门铃</text>
    </view>
  </view>

  <view class="card">
    <view class="setting-item" bindtap="goToEmailSetting">
      <view class="setting-left">
        <view class="setting-icon-wrap email">
          <text class="setting-icon">✉️</text>
        </view>
        <view>
          <text class="setting-label">紧急联系人邮箱</text>
          <text class="setting-desc">紧急呼叫时发送邮件到此邮箱</text>
        </view>
      </view>
      <view class="setting-right">
        <text class="setting-email-preview">{{emergencyEmail || '未设置'}}</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <view class="footer-line"></view>
    <view class="footer-content">
      <view class="footer-status">
        <view class="footer-dot-blue"></view>
        <text class="footer-status-text">系统运行中 · 7×24 小时</text>
      </view>
      <text class="footer-text">💙 听障人士智能门铃系统</text>
      <text class="footer-version">v1.0 · ESP32-S3 · 蓝色守护</text>
    </view>
  </view>
</view>