.container {
    background: #F0F7FF;
    min-height: 100vh;
    padding: 28rpx;
  }
  .profile-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40rpx 0 32rpx 0;
  }
  .profile-avatar {
    width: 120rpx;
    height: 120rpx;
    background: linear-gradient(145deg, #4A90D9, #357ABD);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.30);
    margin-bottom: 16rpx;
  }
  .profile-avatar-icon {
    font-size: 56rpx;
  }
  .profile-name {
    font-size: 36rpx;
    font-weight: 700;
    color: #1A2A4A;
  }
  .profile-desc {
    font-size: 24rpx;
    color: #7A9AB5;
    margin-top: 4rpx;
    letter-spacing: 1rpx;
  }
  .card {
    background: #FFFFFF;
    border-radius: 24rpx;
    padding: 8rpx 0;
    margin-bottom: 22rpx;
    box-shadow: 0 4rpx 28rpx rgba(74, 144, 217, 0.06);
    border: 2rpx solid rgba(74, 144, 217, 0.04);
  }
  .setting-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24rpx 28rpx;
  }
  .setting-left {
    display: flex;
    align-items: center;
    gap: 16rpx;
  }
  .setting-icon-wrap {
    width: 44rpx;
    height: 44rpx;
    border-radius: 12rpx;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .setting-icon-wrap.blue {
    background: #E8F0FE;
  }
  .setting-icon-wrap.email {
    background: #E8F0FE;
  }
  .setting-icon {
    font-size: 24rpx;
  }
  .setting-label {
    font-size: 28rpx;
    color: #1A2A4A;
  }
  .setting-desc {
    font-size: 20rpx;
    color: #B0C8D8;
    display: block;
    margin-top: 2rpx;
  }
  .setting-right {
    display: flex;
    align-items: center;
    gap: 8rpx;
  }
  .setting-email-preview {
    font-size: 24rpx;
    color: #4A90D9;
    max-width: 300rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .setting-arrow {
    font-size: 32rpx;
    color: #C8D8E8;
    margin-left: 8rpx;
  }
  .status-dot-blue {
    width: 12rpx;
    height: 12rpx;
    border-radius: 50%;
    background: #4A90D9;
    animation: pulseBlue 2s ease-in-out infinite;
  }
  @keyframes pulseBlue {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }
  .status-online {
    font-size: 24rpx;
    color: #4A90D9;
    font-weight: 500;
  }
  .setting-value {
    font-size: 26rpx;
    color: #7A9AB5;
  }
  .setting-divider {
    height: 2rpx;
    background: #F0F7FF;
    margin: 0 28rpx;
  }
  .footer {
    padding: 20rpx 0 10rpx 0;
  }
  .footer-line {
    width: 60rpx;
    height: 4rpx;
    background: #C8D8E8;
    border-radius: 4rpx;
    margin: 0 auto 16rpx auto;
  }
  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rpx;
  }
  .footer-status {
    display: flex;
    align-items: center;
    gap: 10rpx;
    margin-bottom: 6rpx;
  }
  .footer-dot-blue {
    width: 10rpx;
    height: 10rpx;
    border-radius: 50%;
    background: #4A90D9;
    animation: pulseBlue 2s ease-in-out infinite;
  }
  .footer-status-text {
    font-size: 20rpx;
    color: #7A9AB5;
    letter-spacing: 2rpx;
  }
  .footer-text {
    font-size: 22rpx;
    color: #7A9AB5;
    letter-spacing: 2rpx;
  }
  .footer-version {
    font-size: 18rpx;
    color: #B0C8D8;
    letter-spacing: 1rpx;
  }