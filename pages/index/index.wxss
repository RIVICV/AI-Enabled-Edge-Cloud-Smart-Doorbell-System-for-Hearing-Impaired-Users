/* ============================================================
   优雅版首页 🌱
   ============================================================ */

   .container {
    background: #F5FBF5;
    min-height: 100vh;
    padding: 0 28rpx 40rpx 28rpx;
  }
  
  /* ===== 顶部状态栏 ===== */
  .header {
    background: linear-gradient(145deg, #9FD8A0 0%, #6BBF7A 50%, #4CAF6A 100%);
    margin: 0 -28rpx 28rpx -28rpx;
    padding: 40rpx 36rpx 30rpx 36rpx;
    border-radius: 0 0 48rpx 48rpx;
    position: relative;
    overflow: hidden;
    box-shadow: 0 12rpx 48rpx rgba(76, 175, 106, 0.30);
  }
  
  .header-glow {
    position: absolute;
    top: -80rpx;
    right: -80rpx;
    width: 300rpx;
    height: 300rpx;
    background: radial-gradient(circle, rgba(255,255,255,0.10) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  
  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    position: relative;
    z-index: 1;
  }
  
  .header-left {
    display: flex;
    align-items: center;
    gap: 16rpx;
  }
  
  .header-logo {
    width: 56rpx;
    height: 56rpx;
    background: rgba(255, 255, 255, 0.20);
    border-radius: 18rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(12rpx);
    border: 2rpx solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  }
  
  .header-icon {
    font-size: 30rpx;
  }
  
  .header-info {
    display: flex;
    flex-direction: column;
    gap: 2rpx;
  }
  
  .header-title {
    font-size: 34rpx;
    font-weight: 700;
    color: #FFFFFF;
    letter-spacing: 2rpx;
    text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  }
  
  .header-sub {
    font-size: 20rpx;
    color: rgba(255, 255, 255, 0.80);
    letter-spacing: 1rpx;
  }
  
  .header-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8rpx;
  }
  
  .header-time {
    font-size: 24rpx;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 300;
    letter-spacing: 2rpx;
    background: rgba(255,255,255,0.12);
    padding: 4rpx 16rpx;
    border-radius: 20rpx;
    backdrop-filter: blur(8rpx);
  }
  
  .status-badge {
    display: flex;
    align-items: center;
    gap: 10rpx;
    padding: 6rpx 20rpx;
    border-radius: 30rpx;
    font-size: 22rpx;
    background: rgba(255, 255, 255, 0.18);
    color: #FFFFFF;
    backdrop-filter: blur(12rpx);
    border: 2rpx solid rgba(255, 255, 255, 0.10);
  }
  
  .status-dot {
    width: 14rpx;
    height: 14rpx;
    border-radius: 50%;
    background: #FFD93D;
    animation: pulse 2s ease-in-out infinite;
    box-shadow: 0 0 12rpx rgba(255, 217, 61, 0.40);
  }
  
  .status-badge.offline .status-dot {
    background: #FF6B6B;
    animation: none;
    box-shadow: none;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }
  
  /* ===== 问候语区域 ===== */
  .greeting-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 16rpx;
    position: relative;
    z-index: 1;
    padding-top: 16rpx;
    border-top: 2rpx solid rgba(255, 255, 255, 0.12);
  }
  
  .greeting-left {
    display: flex;
    align-items: center;
    gap: 10rpx;
  }
  
  .greeting-emoji {
    font-size: 28rpx;
  }
  
  .greeting-text {
    font-size: 26rpx;
    color: rgba(255, 255, 255, 0.90);
    font-weight: 400;
    letter-spacing: 1rpx;
  }
  
  .greeting-highlight {
    font-weight: 700;
    color: #FFD93D;
    font-size: 30rpx;
  }
  
  .today-stats {
    display: flex;
    align-items: baseline;
    gap: 6rpx;
    background: rgba(255, 255, 255, 0.15);
    padding: 6rpx 20rpx;
    border-radius: 24rpx;
    backdrop-filter: blur(12rpx);
    border: 2rpx solid rgba(255, 255, 255, 0.08);
  }
  
  .today-number {
    font-size: 32rpx;
    font-weight: 700;
    color: #FFFFFF;
    text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  }
  
  .today-label {
    font-size: 20rpx;
    color: rgba(255, 255, 255, 0.75);
  }
  
  /* ===== 叶子装饰 ===== */
  .header-decoration {
    position: absolute;
    right: 20rpx;
    top: 20rpx;
    width: 160rpx;
    height: 160rpx;
    opacity: 0.10;
    z-index: 0;
  }
  
  .leaf {
    position: absolute;
    border-radius: 0 50% 50% 50%;
    background: #FFFFFF;
  }
  
  .leaf-1 { top: 0; left: 20rpx; width: 24rpx; height: 24rpx; transform: rotate(45deg); }
  .leaf-2 { top: 12rpx; left: 52rpx; width: 40rpx; height: 40rpx; transform: rotate(60deg); }
  .leaf-3 { top: 48rpx; left: 24rpx; width: 28rpx; height: 28rpx; transform: rotate(30deg); }
  .leaf-4 { top: 70rpx; left: 70rpx; width: 20rpx; height: 20rpx; transform: rotate(80deg); }
  .leaf-5 { top: 90rpx; left: 40rpx; width: 16rpx; height: 16rpx; transform: rotate(120deg); }
  
  /* ===== 卡片通用 ===== */
  .card {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(20rpx);
    border-radius: 28rpx;
    padding: 28rpx;
    margin-bottom: 22rpx;
    box-shadow: 0 4rpx 32rpx rgba(76, 175, 106, 0.06),
                0 1rpx 8rpx rgba(76, 175, 106, 0.02);
    border: 2rpx solid rgba(255, 255, 255, 0.60);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .card:active {
    transform: scale(0.995);
  }
  
  /* ===== 设备状态卡片 ===== */
  .status-card {
    padding: 16rpx 20rpx;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20rpx);
    border: 2rpx solid rgba(255, 255, 255, 0.50);
  }
  
  .status-grid {
    display: flex;
    align-items: center;
    justify-content: space-around;
  }
  
  .status-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rpx;
    flex: 1;
  }
  
  .status-icon-wrap {
    width: 56rpx;
    height: 56rpx;
    border-radius: 18rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4rpx;
    transition: transform 0.3s ease;
  }
  
  .status-icon-wrap:active {
    transform: scale(0.92);
  }
  
  .status-icon-wrap.wifi { background: #E8F5E8; }
  .status-icon-wrap.mqtt { background: #E8F5E8; }
  .status-icon-wrap.server { background: #E8F5E8; }
  .status-icon-wrap.stats { background: #FFF3E0; }
  
  .status-item-icon {
    font-size: 26rpx;
  }
  
  .status-item-label {
    font-size: 20rpx;
    color: #A8D0A8;
  }
  
  .status-item-value {
    font-size: 22rpx;
    color: #2A4030;
    font-weight: 600;
  }
  
  .status-item-value.online-text {
    color: #6BBF7A;
  }
  
  .status-item-value.highlight {
    color: #FF8A65;
    font-size: 24rpx;
  }
  
  .status-divider {
    width: 2rpx;
    height: 48rpx;
    background: #E8F5E8;
  }
  
  /* ===== 卡片头部 ===== */
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20rpx;
  }
  
  .card-header-left {
    display: flex;
    align-items: center;
    gap: 14rpx;
  }
  
  .card-icon-wrap {
    width: 48rpx;
    height: 48rpx;
    background: #E8F5E8;
    border-radius: 16rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  
  .card-icon-wrap.green {
    background: #E8F5E8;
  }
  
  .card-icon {
    font-size: 26rpx;
  }
  
  .card-title {
    font-size: 30rpx;
    font-weight: 600;
    color: #2A4030;
  }
  
  .card-subtitle {
    font-size: 20rpx;
    color: #A8D0A8;
    display: block;
    margin-top: 2rpx;
  }
  
  .card-badge {
    font-size: 18rpx;
    background: linear-gradient(135deg, #9FD8A0, #6BBF7A);
    color: #FFFFFF;
    padding: 4rpx 18rpx;
    border-radius: 24rpx;
    font-weight: 500;
    box-shadow: 0 4rpx 16rpx rgba(76, 175, 106, 0.25);
  }
  
  .card-more {
    font-size: 24rpx;
    color: #6BBF7A;
    padding: 6rpx 4rpx;
    font-weight: 500;
    transition: opacity 0.3s ease;
  }
  
  .card-more:active {
    opacity: 0.5;
  }
  
  /* ===== AI 问答卡片 ===== */
  .chat-card {
    border-left: 6rpx solid #6BBF7A;
  }
  
  .input-wrapper {
    display: flex;
    gap: 12rpx;
    align-items: center;
    background: #F8FCF8;
    border-radius: 60rpx;
    padding: 4rpx 4rpx 4rpx 24rpx;
    border: 2rpx solid #E8F5E8;
    transition: all 0.3s ease;
    box-shadow: inset 0 2rpx 8rpx rgba(0,0,0,0.02);
  }
  
  .input-wrapper:focus-within {
    border-color: #6BBF7A;
    box-shadow: 0 0 0 8rpx rgba(76, 175, 106, 0.06),
                inset 0 2rpx 8rpx rgba(0,0,0,0.02);
  }
  
  .input-icon {
    font-size: 24rpx;
    color: #A8D0A8;
  }
  
  .question-input {
    flex: 1;
    height: 68rpx;
    font-size: 27rpx;
    color: #2A4030;
  }
  
  .question-input::placeholder {
    color: #B8D8B8;
  }
  
  .send-btn {
    width: 68rpx;
    height: 68rpx;
    border-radius: 50%;
    background: #E8F5E8;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 0;
  }
  
  .send-btn .send-icon {
    font-size: 28rpx;
    color: #A8D0A8;
    transition: all 0.3s ease;
  }
  
  .send-btn.active {
    background: linear-gradient(145deg, #9FD8A0, #6BBF7A);
    box-shadow: 0 4rpx 20rpx rgba(76, 175, 106, 0.30);
  }
  
  .send-btn.active .send-icon {
    color: #FFFFFF;
  }
  
  .send-btn.active:active {
    transform: scale(0.88);
  }
  
  /* ===== AI 回答 ===== */
  .answer-area {
    margin-top: 22rpx;
    padding: 24rpx;
    background: #F8FCF8;
    border-radius: 20rpx;
    border-left: 4rpx solid #6BBF7A;
    animation: fadeSlideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(20rpx); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .answer-header {
    display: flex;
    align-items: center;
    gap: 14rpx;
    margin-bottom: 12rpx;
  }
  
  .answer-avatar {
    width: 48rpx;
    height: 48rpx;
    background: linear-gradient(145deg, #9FD8A0, #6BBF7A);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24rpx;
    flex-shrink: 0;
    box-shadow: 0 4rpx 16rpx rgba(76, 175, 106, 0.20);
  }
  
  .answer-info {
    display: flex;
    flex-direction: column;
    gap: 2rpx;
  }
  
  .answer-name {
    font-size: 26rpx;
    font-weight: 600;
    color: #2A4030;
  }
  
  .answer-time {
    font-size: 20rpx;
    color: #A8D0A8;
  }
  
  .answer-badge {
    font-size: 16rpx;
    color: #6BBF7A;
    background: #E8F5E8;
    padding: 2rpx 16rpx;
    border-radius: 20rpx;
    margin-left: auto;
  }
  
  .answer-content {
    font-size: 29rpx;
    color: #2A4030;
    line-height: 1.8;
    padding-left: 4rpx;
  }
  
  /* ===== 快捷提问 ===== */
  .quick-section {
    margin-top: 22rpx;
  }
  
  .quick-label {
    font-size: 24rpx;
    color: #A8D0A8;
    display: block;
    margin-bottom: 14rpx;
    letter-spacing: 1rpx;
  }
  
  .quick-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 14rpx;
  }
  
  .quick-item {
    display: flex;
    align-items: center;
    gap: 12rpx;
    padding: 16rpx 22rpx;
    background: #F8FCF8;
    border-radius: 20rpx;
    font-size: 25rpx;
    color: #2A4030;
    border: 2rpx solid #E8F5E8;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    flex: 1;
    min-width: 200rpx;
    box-sizing: border-box;
  }
  
  .quick-item:active {
    background: #6BBF7A;
    color: #FFFFFF;
    border-color: #6BBF7A;
    transform: scale(0.96);
  }
  
  .quick-item:active .quick-icon-wrap {
    background: rgba(255, 255, 255, 0.20);
  }
  
  .quick-icon-wrap {
    width: 36rpx;
    height: 36rpx;
    border-radius: 12rpx;
    background: #E8F5E8;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.3s ease;
  }
  
  .quick-icon {
    font-size: 20rpx;
  }
  
  /* ===== 最近来访卡片 ===== */
  .recent-card {
    border-left: 6rpx solid #4CAF6A;
  }
  
  .recent-list {
    display: flex;
    flex-direction: column;
    gap: 2rpx;
  }
  
  .recent-item {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    padding: 16rpx 0;
    border-bottom: 2rpx solid #F0FBF0;
    gap: 8rpx;
  }
  
  .recent-item:last-child {
    border-bottom: none;
  }
  
  .recent-item.new-item {
    background: #F8FCF8;
    border-radius: 16rpx;
    padding: 16rpx 18rpx;
    margin: 0 -10rpx;
    border: 2rpx solid rgba(107, 191, 122, 0.20);
    animation: highlightPulse 2s ease-in-out 2;
  }
  
  @keyframes highlightPulse {
    0%, 100% { border-color: rgba(107, 191, 122, 0.15); }
    50% { border-color: rgba(107, 191, 122, 0.45); }
  }
  
  .recent-left {
    display: flex;
    align-items: center;
    gap: 14rpx;
  }
  
  .recent-dot {
    width: 10rpx;
    height: 10rpx;
    border-radius: 50%;
    background: #6BBF7A;
    flex-shrink: 0;
  }
  
  .recent-dot.emergency-dot {
    background: #FF6B6B;
  }
  
  .recent-info {
    display: flex;
    flex-direction: column;
    gap: 2rpx;
  }
  
  .recent-time {
    font-size: 24rpx;
    color: #A8D0A8;
  }
  
  .recent-type {
    font-size: 20rpx;
    color: #B8D8B8;
  }
  
  .recent-right {
    display: flex;
    align-items: center;
    gap: 12rpx;
    flex-wrap: wrap;
  }
  
  .recent-tag {
    padding: 6rpx 20rpx;
    background: #F8FCF8;
    border-radius: 24rpx;
    border: 2rpx solid #E8F5E8;
  }
  
  .recent-msg {
    font-size: 25rpx;
    color: #2A4030;
    font-weight: 500;
  }
  
  .new-badge {
    font-size: 16rpx;
    color: #4CAF6A;
    background: #E8F5E8;
    padding: 2rpx 16rpx;
    border-radius: 20rpx;
    font-weight: 500;
    animation: badgePulse 1.5s ease-in-out infinite;
  }
  
  @keyframes badgePulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  
  /* ===== 空状态 ===== */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 36rpx 0 16rpx 0;
  }
  
  .empty-icon-wrap {
    width: 80rpx;
    height: 80rpx;
    background: #F8FCF8;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14rpx;
  }
  
  .empty-icon {
    font-size: 44rpx;
  }
  
  .empty-text {
    font-size: 27rpx;
    color: #A8D0A8;
  }
  
  .empty-hint {
    font-size: 22rpx;
    color: #C8E0C8;
    margin-top: 6rpx;
  }
  
  /* ===== 底部信息 ===== */
  .footer {
    padding: 20rpx 0 10rpx 0;
  }
  
  .footer-line {
    width: 60rpx;
    height: 4rpx;
    background: #C8E0C8;
    border-radius: 4rpx;
    margin: 0 auto 16rpx auto;
  }
  
  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rpx;
  }
  
  .footer-status {
    display: flex;
    align-items: center;
    gap: 10rpx;
    margin-bottom: 6rpx;
  }
  
  .footer-dot {
    width: 10rpx;
    height: 10rpx;
    border-radius: 50%;
    background: #6BBF7A;
    animation: pulse 2s ease-in-out infinite;
  }
  
  .footer-status-text {
    font-size: 20rpx;
    color: #A8D0A8;
    letter-spacing: 2rpx;
  }
  
  .footer-text {
    font-size: 22rpx;
    color: #A8D0A8;
    letter-spacing: 2rpx;
  }
  
  .footer-version {
    font-size: 18rpx;
    color: #C8E0C8;
    letter-spacing: 1rpx;
  }