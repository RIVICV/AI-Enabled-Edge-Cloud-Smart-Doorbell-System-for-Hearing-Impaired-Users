<view class="container">
  <!-- ===== 顶部统计 ===== -->
  <view class="stats-bar">
    <view class="stats-item">
      <text class="stats-number">{{records.length}}</text>
      <text class="stats-label">🌸 总来访</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-number">{{todayCount}}</text>
      <text class="stats-label">🌷 今日</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-number">{{weekCount}}</text>
      <text class="stats-label">🌺 本周</text>
    </view>
  </view>

  <!-- ===== 列表头部 ===== -->
  <view class="list-header">
    <text class="list-title">📋 全部记录</text>
    <text class="list-count">共 {{records.length}} 条</text>
  </view>

  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <view wx:elif="{{records.length > 0}}" class="record-list">
    <view wx:for="{{records}}" wx:key="id" class="record-item {{item.event_type === 'emergency' ? 'emergency-item' : ''}}">
      <view class="record-top">
        <view class="record-left">
          <view class="record-dot {{item.event_type === 'emergency' ? 'dot-emergency' : 'dot-normal'}}"></view>
          <view class="record-info">
            <text class="record-date">{{item.trigger_time}}</text>
            <text class="record-type">{{item.event_type === 'emergency' ? '🚨 紧急' : '🔔 门铃'}}</text>
          </view>
        </view>
        <view class="record-tag {{item.event_type === 'emergency' ? 'tag-emergency' : 'tag-normal'}}">
          {{item.event_type === 'emergency' ? '紧急' : '来访'}}
        </view>
      </view>
      <text class="record-msg">{{item.msg_content || '普通来访'}}</text>
    </view>
  </view>

  <view wx:else class="empty-state">
    <text class="empty-icon">🌸</text>
    <text class="empty-text">暂无来访记录</text>
    <text class="empty-hint">门铃响起后这里会显示</text>
  </view>
</view>